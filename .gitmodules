[submodule ".registry"]
	path = .registry
	url = https://github.com/learnitr/learnitr.r-universe.dev
	branch = HEAD
[submodule "learnitdashboard"]
	path = learnitdashboard
	url = https://github.com/learnitr/learnitdashboard
[submodule "learnitdown"]
	path = learnitdown
	url = https://github.com/learnitr/learnitdown
[submodule "learnitgrid"]
	path = learnitgrid
	url = https://github.com/learnitr/learnitgrid
[submodule "learnitprogress"]
	path = learnitprogress
	url = https://github.com/learnitr/learnitprogress
